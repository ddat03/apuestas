# Copia este archivo como .env y rellena tus claves reales
# cp .env.example .env

# ─── API-Football (via RapidAPI o directo) ───────────────
# Regístrate en https://rapidapi.com/api-sports/api/api-football
# Plan Free: 100 peticiones/día
API_FOOTBALL_KEY=
RAPIDAPI_KEY=

# ─── The Odds API (odds gratuitas) ───────────────────────
# Regístrate en https://the-odds-api.com/
# Plan Free: 500 peticiones/mes — SUFICIENTE para este sistema
THE_ODDS_API_KEY=

# ─── OpenAI ───────────────────────────────────────────────
# Consigue tu key en https://platform.openai.com/api-keys
# Modelo recomendado: gpt-4o-mini (barato ~$0.001 por análisis diario)
# Alternativa más potente: gpt-4o
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Telegram Bot ─────────────────────────────────────────
# 1. Habla con @BotFather en Telegram → /newbot
# 2. Copia el token aquí
# 3. Escribe un mensaje a tu bot y visita:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    para obtener tu chat_id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
